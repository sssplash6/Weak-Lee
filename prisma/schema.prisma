// Prisma schema for freshman.academy weekly goal tracker.
// Prisma 7 uses the new `prisma-client` generator with a required output path.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----- Auth.js (NextAuth) models -----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Collected during onboarding after the first Google sign-in. All four are
  // required before a user reaches the dashboard (see lib/profile.ts).
  workPhone        String?
  telegramUsername String?
  department       String?

  // Assigned preset animal avatar (emoji). Unique so no two users share one.
  avatar String? @unique

  accounts Account[]
  sessions Session[]
  weeks    Week[]

  sharesSent     SubtaskShare[] @relation("SharesFrom")
  sharesReceived SubtaskShare[] @relation("SharesTo")
  feedback       Feedback[]

  penalties       Penalty[] @relation("PenaltiesReceived")
  penaltiesIssued Penalty[] @relation("PenaltiesIssued")
  attendances     Attendance[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ----- App models -----

// Goal priority, surfaced as colored flags (green / amber / red). Absent = none.
enum Priority {
  LOW
  MEDIUM
  HIGH
}

// Why a penalty was issued. MEETING_SKIPPED fines are driven by meeting
// attendance (escalating); LATE_SUBMISSION is auto-applied to a late week;
// OTHER is a manual admin fine for anything else.
enum PenaltyType {
  MEETING_SKIPPED
  LATE_SUBMISSION
  OTHER
}

// A fine issued to a user. Amount is a whole number in the app's configured
// currency (see lib/penalties.ts). Optionally linked to the week and/or meeting
// it relates to so it can surface in the right view and be recomputed.
model Penalty {
  id         String      @id @default(cuid())
  userId     String
  type       PenaltyType @default(OTHER)
  amount     Int
  note       String?
  weekId     String?
  meetingId  String?
  issuedById String?
  createdAt  DateTime    @default(now())

  user     User     @relation("PenaltiesReceived", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy User?    @relation("PenaltiesIssued", fields: [issuedById], references: [id], onDelete: SetNull)
  week     Week?    @relation(fields: [weekId], references: [id], onDelete: SetNull)
  meeting  Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([weekId])
  @@index([meetingId])
}

// A recurring team meeting (Monday 11:00 company time). One row per time slot.
model Meeting {
  id          String   @id @default(cuid())
  scheduledAt DateTime @unique
  createdAt   DateTime @default(now())

  attendances Attendance[]
  penalties   Penalty[]
}

// Whether a person attended a meeting. There's no automatic arrival detection —
// an admin (Shakhzod) marks each person. EXCUSED = no fine and resets the
// consecutive-skip streak.
enum AttendanceStatus {
  ATTENDED
  SKIPPED
  EXCUSED
}

model Attendance {
  id        String           @id @default(cuid())
  meetingId String
  userId    String
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([userId])
}

model Week {
  id        String   @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(true)
  // True when the week was started (previous week closed + new goals submitted)
  // after the Sunday 12:00 Tashkent deadline. Set when a week is explicitly
  // started; auto-created first weeks stay false. See lib/lateness.ts.
  submittedLate Boolean @default(false)
  // The *first* time the user submitted their goals for this week. Set once and
  // never overwritten or cleared — re-submitting after an edit keeps the
  // original time. Null until the first submit. Surfaced to admins.
  submittedAt DateTime?
  // Whether the goal list is currently locked (submitted state). Submitting sets
  // this true; "Edit goals" sets it false without touching submittedAt.
  goalsLocked Boolean @default(false)
  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals     Goal[]
  penalties Penalty[]

  @@index([userId])
  @@index([userId, isCurrent])
}

model Goal {
  id               String   @id @default(cuid())
  weekId           String
  title            String
  position         Int
  // Reflection captured when closing a week if this goal wasn't marked complete.
  incompleteReason String?
  // Set when the user explicitly marks the goal done. Finishing every subtask
  // does NOT complete a goal on its own — completion is always a deliberate act.
  completedAt      DateTime?
  // Optional due date (stored at UTC midnight; the app treats it as date-only).
  deadline         DateTime?
  // Optional priority flag (none when null).
  priority         Priority?
  createdAt        DateTime  @default(now())

  week     Week      @relation(fields: [weekId], references: [id], onDelete: Cascade)
  subtasks Subtask[]

  @@index([weekId])
}

model Subtask {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  isDone    Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  // Delegation: a subtask may be the original of several shares (shared out)
  // and/or the copy created by a single incoming share (received).
  sharesOut SubtaskShare[] @relation("ShareOriginal")
  shareIn   SubtaskShare?  @relation("ShareCopy")

  @@index([goalId])
}

// A delegation of a subtask from one user to another. The original stays on the
// sender's list (marked "shared to X"); a linked copy is added to the recipient.
model SubtaskShare {
  id                String   @id @default(cuid())
  originalSubtaskId String
  copySubtaskId     String   @unique
  fromUserId        String
  toUserId          String
  createdAt         DateTime @default(now())

  originalSubtask Subtask @relation("ShareOriginal", fields: [originalSubtaskId], references: [id], onDelete: Cascade)
  copySubtask     Subtask @relation("ShareCopy", fields: [copySubtaskId], references: [id], onDelete: Cascade)
  fromUser        User    @relation("SharesFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User    @relation("SharesTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([originalSubtaskId, toUserId])
  @@index([originalSubtaskId])
}

// Product feedback addressed to tech@freshman.academy. Stored here rather than
// emailed (no mail provider configured); read straight from the table. The
// submitter's email is captured at write time so it survives user deletion.
model Feedback {
  id        String   @id @default(cuid())
  message   String
  userId    String?
  userEmail String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
