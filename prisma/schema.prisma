// Prisma schema for freshman.academy weekly goal tracker.
// Prisma 7 uses the new `prisma-client` generator with a required output path.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ----- Auth.js (NextAuth) models -----

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  // Collected during onboarding after the first Google sign-in. These are
  // required before a user reaches the dashboard (see lib/profile.ts).
  workPhone        String?
  telegramUsername String?
  department       String?
  birthday         DateTime? // stored at UTC midnight, treated as a calendar day

  // Optional social handles, editable from the profile page. Shown on /team.
  linkedin  String?
  instagram String?

  // Assigned preset animal avatar (emoji). Unique so no two users share one.
  avatar String? @unique

  // How much of their fines this person has paid back so far (whole USD), set by
  // admins on the penalties page. Outstanding = total fines issued − finesPaid.
  finesPaid Int @default(0)

  accounts Account[]
  sessions Session[]
  weeks    Week[]
  months   Month[]

  sharesSent     SubtaskShare[] @relation("SharesFrom")
  sharesReceived SubtaskShare[] @relation("SharesTo")
  goalSharesSent     GoalShare[] @relation("GoalSharesFrom")
  goalSharesReceived GoalShare[] @relation("GoalSharesTo")
  feedback       Feedback[]

  penalties       Penalty[] @relation("PenaltiesReceived")
  penaltiesIssued Penalty[] @relation("PenaltiesIssued")
  bonuses         Bonus[]   @relation("BonusesReceived")
  bonusesIssued   Bonus[]   @relation("BonusesIssued")
  assignedTasks   AssignedTask[] @relation("AssignedReceived")
  tasksAssigned   AssignedTask[] @relation("AssignedIssued")
  attendances     Attendance[]
  notifications   Notification[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ----- App models -----

// Goal priority, surfaced as colored flags (green / amber / red). Absent = none.
enum Priority {
  LOW
  MEDIUM
  HIGH
}

// Why a penalty was issued. MEETING_SKIPPED fines are driven by meeting
// attendance (escalating); LATE_SUBMISSION is auto-applied to a late week;
// OTHER is a manual admin fine for anything else.
enum PenaltyType {
  MEETING_SKIPPED
  MEETING_LATE
  LATE_SUBMISSION
  OTHER
}

// A fine issued to a user. Amount is a whole number in the app's configured
// currency (see lib/penalties.ts). Optionally linked to the week and/or meeting
// it relates to so it can surface in the right view and be recomputed.
model Penalty {
  id         String      @id @default(cuid())
  userId     String
  type       PenaltyType @default(OTHER)
  amount     Int
  note       String?
  weekId     String?
  meetingId  String?
  issuedById String?
  createdAt  DateTime    @default(now())

  user     User     @relation("PenaltiesReceived", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy User?    @relation("PenaltiesIssued", fields: [issuedById], references: [id], onDelete: SetNull)
  week     Week?    @relation(fields: [weekId], references: [id], onDelete: SetNull)
  meeting  Meeting? @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([weekId])
  @@index([meetingId])
}

// A bonus awarded to a user — the positive counterpart of a Penalty, tracked
// separately (no netting against fines). Amount is a whole number in the app's
// configured currency (see lib/penalties.ts formatMoney).
model Bonus {
  id         String   @id @default(cuid())
  userId     String
  amount     Int
  note       String?
  issuedById String?
  createdAt  DateTime @default(now())

  user     User  @relation("BonusesReceived", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy User? @relation("BonusesIssued", fields: [issuedById], references: [id], onDelete: SetNull)

  @@index([userId])
}

// Whether an assigned goal is a weekly or a monthly one — controls which
// dashboard view (week/month) surfaces it to the assignee.
enum AssignScope {
  WEEKLY
  MONTHLY
}

// A goal an admin assigns to a specific person. Lives outside the weekly/monthly
// goal flow — it's a standalone task the assignee tracks and marks done, and it
// does NOT count toward their week completion percent.
model AssignedTask {
  id           String    @id @default(cuid())
  userId       String
  assignedById String?
  title        String
  note         String?
  scope        AssignScope @default(WEEKLY)
  deadline     DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())

  user       User  @relation("AssignedReceived", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("AssignedIssued", fields: [assignedById], references: [id], onDelete: SetNull)

  @@index([userId])
}

// What a notification is about — drives its color/icon in the updates feed.
enum NotificationType {
  FINE
  BONUS
  TASK_ASSIGNED
  REPORT
  OTHER
}

// An in-app notification addressed to one user. Written alongside fines,
// bonuses, task assignments, and colleague reports (see lib/notifications.ts),
// and surfaced in the dashboard's "Last 48 hours" updates zone. `readAt` is
// set when the user marks their notifications read — it drives the bell badge.
model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType @default(OTHER)
  message   String
  createdAt DateTime         @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// A recurring team meeting (Monday 11:00 company time). One row per time slot.
model Meeting {
  id          String   @id @default(cuid())
  scheduledAt DateTime @unique
  createdAt   DateTime @default(now())

  attendances Attendance[]
  penalties   Penalty[]
}

// Whether a person attended a meeting. There's no automatic arrival detection —
// an admin (Shakhzod) marks each person. EXCUSED = no fine and resets the
// consecutive-skip streak. LATE = flat fine but counts as present, so it also
// resets the streak.
enum AttendanceStatus {
  ATTENDED
  LATE
  SKIPPED
  EXCUSED
}

model Attendance {
  id        String           @id @default(cuid())
  meetingId String
  userId    String
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingId, userId])
  @@index([userId])
}

model Week {
  id        String   @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(true)
  // True when the week was started (previous week closed + new goals submitted)
  // after the Sunday 12:00 Tashkent deadline. Set when a week is explicitly
  // started; auto-created first weeks stay false. See lib/lateness.ts.
  submittedLate Boolean @default(false)
  // The *first* time the user submitted their goals for this week. Set once and
  // never overwritten or cleared — re-submitting after an edit keeps the
  // original time. Null until the first submit. Surfaced to admins.
  submittedAt DateTime?
  // Whether the goal list is currently locked (submitted state). Submitting sets
  // this true; "Edit goals" sets it false without touching submittedAt.
  goalsLocked Boolean @default(false)
  createdAt DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals     Goal[]
  penalties Penalty[]

  @@index([userId])
  @@index([userId, isCurrent])
}

// The monthly counterpart of Week. Same submit/lock/close lifecycle, but with
// no submission deadline (so no lateness flag or penalties). Months are always
// whole calendar months.
model Month {
  id        String   @id @default(cuid())
  userId    String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(true)
  // First goal submission for this month — set once, never overwritten (same
  // semantics as Week.submittedAt).
  submittedAt DateTime?
  goalsLocked Boolean   @default(false)
  createdAt   DateTime  @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  goals Goal[]

  @@index([userId])
  @@index([userId, isCurrent])
}

model Goal {
  id               String   @id @default(cuid())
  // A goal belongs to exactly one period: either a week or a month.
  weekId           String?
  monthId          String?
  title            String
  position         Int
  // Reflection captured when closing a week if this goal wasn't marked complete.
  incompleteReason String?
  // Set when the user explicitly marks the goal done. Finishing every subtask
  // does NOT complete a goal on its own — completion is always a deliberate act.
  completedAt      DateTime?
  // Optional due date (stored at UTC midnight; the app treats it as date-only).
  deadline         DateTime?
  // Optional priority flag (none when null).
  priority         Priority?
  // Manual progress override (0–100) typed by the user in place of the
  // subtask-derived percent. Cleared whenever a subtask is toggled so the
  // derived value takes back over. A completed goal always reads 100.
  manualPercent    Int?
  createdAt        DateTime  @default(now())

  week     Week?     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  month    Month?    @relation(fields: [monthId], references: [id], onDelete: Cascade)
  subtasks Subtask[]

  // Delegation: a goal may be the original of several shares (shared out)
  // and/or the copy created by a single incoming share (received). Mirrors
  // the subtask fields of the same names.
  sharesOut GoalShare[] @relation("GoalShareOriginal")
  shareIn   GoalShare?  @relation("GoalShareCopy")

  @@index([weekId])
  @@index([monthId])
}

model Subtask {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  isDone    Boolean  @default(false)
  position  Int
  createdAt DateTime @default(now())

  goal Goal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  // Delegation: a subtask may be the original of several shares (shared out)
  // and/or the copy created by a single incoming share (received).
  sharesOut SubtaskShare[] @relation("ShareOriginal")
  shareIn   SubtaskShare?  @relation("ShareCopy")

  @@index([goalId])
}

// A delegation of a subtask from one user to another. The original stays on the
// sender's list (marked "shared to X"); a linked copy is added to the recipient.
model SubtaskShare {
  id                String   @id @default(cuid())
  originalSubtaskId String
  copySubtaskId     String   @unique
  fromUserId        String
  toUserId          String
  createdAt         DateTime @default(now())

  originalSubtask Subtask @relation("ShareOriginal", fields: [originalSubtaskId], references: [id], onDelete: Cascade)
  copySubtask     Subtask @relation("ShareCopy", fields: [copySubtaskId], references: [id], onDelete: Cascade)
  fromUser        User    @relation("SharesFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User    @relation("SharesTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([originalSubtaskId, toUserId])
  @@index([originalSubtaskId])
}

// A delegation of a whole goal (with or without subtasks) from one user to
// another. Same shape as SubtaskShare: the original stays on the sender's list
// (marked "shared to X"); a linked copy — goal plus fresh unchecked subtasks —
// is added to the recipient's current period.
model GoalShare {
  id             String   @id @default(cuid())
  originalGoalId String
  copyGoalId     String   @unique
  fromUserId     String
  toUserId       String
  createdAt      DateTime @default(now())

  originalGoal Goal @relation("GoalShareOriginal", fields: [originalGoalId], references: [id], onDelete: Cascade)
  copyGoal     Goal @relation("GoalShareCopy", fields: [copyGoalId], references: [id], onDelete: Cascade)
  fromUser     User @relation("GoalSharesFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User @relation("GoalSharesTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([originalGoalId, toUserId])
  @@index([originalGoalId])
}

// Product feedback addressed to tech@freshman.academy. Stored here rather than
// emailed (no mail provider configured); read straight from the table. The
// submitter's email is captured at write time so it survives user deletion.
model Feedback {
  id        String   @id @default(cuid())
  message   String
  userId    String?
  userEmail String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}
